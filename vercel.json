{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://vitals.vercel-insights.com; frame-src 'none'; object-src 'none'; base-uri 'self'"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/cv",
      "destination": "https://cv-terry-li-hm.vercel.app"
    },
    {
      "source": "/cv/(.*)",
      "destination": "https://cv-terry-li-hm.vercel.app/$1"
    },
    {
      "source": "/_next/:path*",
      "destination": "https://cv-terry-li-hm.vercel.app/_next/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "https://cv-terry-li-hm.vercel.app/favicon.ico"
    },
    {
      "source": "/favicon.svg",
      "destination": "https://cv-terry-li-hm.vercel.app/favicon.svg"
    }
  ]
}
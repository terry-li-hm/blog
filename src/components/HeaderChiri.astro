---
import { SITE } from "@/config";
---

<header>
  <nav>
    <a href="/" class="site-title">{SITE.title}</a>
    <div class="nav-links">
      <a href="/about" class="nav-link">
        <span>about</span>
      </a>
      <a href="/search" class="nav-link" aria-label="Search">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M10 6.5C10 8.433 8.433 10 6.5 10C4.567 10 3 8.433 3 6.5C3 4.567 4.567 3 6.5 3C8.433 3 10 4.567 10 6.5ZM9.31 10.017C8.57 10.62 7.627 11 6.5 11C4.015 11 2 8.985 2 6.5C2 4.015 4.015 2 6.5 2C8.985 2 11 4.015 11 6.5C11 7.627 10.62 8.57 10.017 9.31L12.853 12.147C13.049 12.342 13.049 12.659 12.853 12.854C12.658 13.049 12.341 13.049 12.146 12.854L9.31 10.017Z" fill="currentColor" fill-rule="evenodd" clip-rule="evenodd"></path>
        </svg>
        <span>search</span>
      </a>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-title {
    font-family: var(--serif);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    text-decoration: none;
    min-width: 3rem;
    display: inline-block;
    font-size: 1.125rem;
    letter-spacing: 0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--font-size-s);
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link svg {
    flex-shrink: 0;
  }
</style>
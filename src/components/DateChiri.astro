---
export interface Props {
  pubDatetime: string | Date;
  modDatetime?: string | Date | null;
  readingTime?: number;
  revisionNote?: string;
}

const { pubDatetime, modDatetime, readingTime, revisionNote } = Astro.props;

const isRevised = modDatetime && new Date(modDatetime) > new Date(pubDatetime);
const displayDate = isRevised ? modDatetime! : pubDatetime;
const date = new Date(displayDate);

// Format as YYYY.MM.DD like Chiri
const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, "0");
const day = String(date.getDate()).padStart(2, "0");
const formattedDate = `${year}.${month}.${day}`;
---

<p class="date">
  <time datetime={date.toISOString()}>{formattedDate}</time>
  {isRevised && <span class="revised-marker"> · revised</span>}
  {readingTime && <span class="reading-time"> · {readingTime} min read</span>}
</p>
{isRevised && revisionNote && (
  <p class="revision-note">{revisionNote}</p>
)}

<style>
  .date {
    margin: 0;
    color: var(--text-secondary);
    opacity: 0.75;
    letter-spacing: var(--spacing-s);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .revised-marker {
    font-style: italic;
  }
  .revision-note {
    margin: 0.25rem 0 0;
    color: var(--text-secondary);
    opacity: 0.65;
    font-size: 0.85em;
    font-style: italic;
  }
</style>